FLASK_ENV=development
SECRET_KEY=ganti-dengan-secret-key-yang-panjang-dan-acak

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=amonialele

# MQTT Broker (Mosquitto)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=lele_server
MQTT_PASSWORD=mqttpassword
MQTT_CLIENT_ID=amonialele-server
MQTT_TOPIC_SUBSCRIBE=lele/+/data
MQTT_TOPIC_LWT=lele/+/status

# Telegram Bot
TELEGRAM_BOT_TOKEN=isi-dengan-token-bot-telegram-kamu
